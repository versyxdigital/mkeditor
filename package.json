{
  "name": "mkeditor",
  "productName": "MKEditor",
  "version": "4.1.0",
  "license": "MIT",
  "author": "Chris Rowles <christopher.rowles@outlook.com>",
  "description": "Markdown Editor",
  "main": "dist/app/main.js",
  "scripts": {
    "prepare": "husky",
    "prettier-check": "prettier . --check",
    "prettier-fix": "prettier . --write",
    "lint": "eslint src",
    "test": "jest",
    "prebuild": "node -p \"\\\"export const APP_VERSION = '\\\" + require('./package.json').version + \\\"';\\\"\" > src/browser/version.ts",
    "build-editor": "npm run prebuild && node ./scripts/combine-locales.mjs && webpack --config webpack.config.js",
    "build-app": "node ./scripts/compile-app.mjs",
    "build-all": "npm run build-editor && npm run build-app",
    "make-installer": "node ./scripts/make-installer.mjs",
    "serve-web": "http-server dist",
    "serve-app": "electron .",
    "publish": "npm run build-editor && npm run build-app && electron-builder --publish always"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/versyxdigital/mkeditor"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-container": "^4.0.0",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/wicg-file-system-access": "^2023.10.7",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "autoprefixer": "^10.5.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "electron": "^42.1.0",
    "electron-builder": "^26.0.12",
    "eslint": "^10.4.0",
    "file-loader": "^6.2.0",
    "globals": "^17.6.0",
    "html-minimizer-webpack-plugin": "^6.0.0",
    "html-webpack-plugin": "^5.6.7",
    "husky": "9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "monaco-editor-webpack-plugin": "^7.1.1",
    "postcss": "^8.5.14",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.8",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.3.0",
    "terser-webpack-plugin": "^5.3.14",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "webpack": "^5.101.3",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@ai-sdk/openai": "^3.0.64",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@vscode/markdown-it-katex": "^1.1.2",
    "ai": "^6.0.184",
    "circle-buffer": "^0.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "highlight.js": "^11.11.1",
    "i18next": "^26.2.0",
    "markdown-it": "^14.1.0",
    "markdown-it-container": "^4.0.0",
    "monaco-editor": "^0.55.1",
    "ollama-ai-provider-v2": "^3.5.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-resizable-panels": "^4.11.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "build": {
    "appId": "com.mkeditor.app",
    "artifactName": "mkeditor-setup-${version}.${ext}",
    "directories": {
      "output": "releases/${platform}/${arch}"
    },
    "fileAssociations": [
      {
        "ext": [
          "md"
        ],
        "name": "Plain Text",
        "role": "Editor"
      }
    ],
    "linux": {
      "target": "deb",
      "icon": "build/resources/icon256x256.png",
      "category": "Utility"
    },
    "mac": {
      "target": "pkg",
      "icon": "build/resources/icon512x512.png"
    },
    "win": {
      "target": "nsis",
      "icon": "build/resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "installerIcon": "build/resources/icon.ico",
      "license": "build/resources/license.txt"
    },
    "pkg": {
      "license": "build/resources/license.txt"
    },
    "publish": {
      "provider": "github",
      "owner": "versyxdigital",
      "repo": "mkeditor"
    }
  }
}
